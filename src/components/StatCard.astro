---
interface Props {
  value: string;
  label: string;
  color?: string;
}

const { value, label, color = 'text-euclid-teal' } = Astro.props;
---

<div class="stat-card group hover:border-euclid-teal/30 transition-all">
  <div class={`text-3xl md:text-4xl font-poppins font-bold ${color} mb-2`}>{value}</div>
  <div class="text-sm text-gray-500 font-roboto leading-snug">{label}</div>
</div>
