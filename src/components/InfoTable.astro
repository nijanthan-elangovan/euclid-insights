---
interface Props {
  headers: string[];
  rows: string[][];
}

const { headers, rows } = Astro.props;
---

<div class="overflow-x-auto my-8 rounded-xl border border-gray-100">
  <table class="info-table">
    <thead>
      <tr>
        {headers.map((h) => (
          <th>{h}</th>
        ))}
      </tr>
    </thead>
    <tbody>
      {rows.map((row) => (
        <tr>
          {row.map((cell, i) => (
            <td class={i === 0 ? 'font-poppins font-semibold text-euclid-navy' : ''}>
              {cell}
            </td>
          ))}
        </tr>
      ))}
    </tbody>
  </table>
</div>
