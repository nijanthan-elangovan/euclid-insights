---
import type { ReviewData } from '../lib/store';

interface Props {
  slug: string;
  userEmail: string;
  userName: string;
  initialReview: ReviewData;
}

const { slug, userEmail, userName, initialReview } = Astro.props;
const hasApproved = initialReview.approved.some((a) => a.email === userEmail);
---

<div id="review-panel" class="fixed right-0 top-20 z-[70] flex pointer-events-none" data-slug={slug} data-email={userEmail} data-name={userName}>
  <!-- Toggle tab -->
  <button
    id="review-toggle"
    class="self-start bg-emerald-600 text-white px-2 py-3 rounded-l-lg shadow-lg hover:bg-emerald-700 transition-colors pointer-events-auto"
    style="writing-mode: vertical-lr; text-orientation: mixed;"
    aria-label="Toggle review panel"
  >
    <span class="text-xs font-poppins font-semibold tracking-wider">REVIEW</span>
  </button>

  <!-- Panel body -->
  <div id="review-body" class="w-80 max-h-[calc(100vh-6rem)] bg-white border border-gray-200 rounded-l-xl shadow-2xl flex flex-col overflow-hidden transition-all duration-200 pointer-events-auto">
    <div class="p-4 border-b border-gray-100 bg-gray-50">
      <h3 class="font-poppins font-semibold text-sm text-gray-800">Article Review</h3>
      <p class="text-xs text-gray-500 mt-1">
        <span id="review-approval-count">{initialReview.approved.length}</span> approval(s)
      </p>
    </div>

    <!-- Approve button -->
    <div class="p-4 border-b border-gray-100">
      <button
        id="review-approve-btn"
        class:list={[
          'w-full py-2 px-4 rounded-lg text-sm font-poppins font-semibold transition-colors',
          hasApproved
            ? 'bg-emerald-100 text-emerald-800 border border-emerald-300'
            : 'bg-emerald-600 text-white hover:bg-emerald-700',
        ]}
        data-approved={hasApproved ? 'true' : 'false'}
      >
        {hasApproved ? 'Approved' : 'Approve'}
      </button>
      <div id="review-approvers" class="mt-2 space-y-1">
        {initialReview.approved.map((a) => (
          <p class="text-xs text-gray-500 font-poppins">{a.name} - {new Date(a.at).toLocaleDateString()}</p>
        ))}
      </div>
    </div>

    <!-- Comments -->
    <div class="flex-1 overflow-y-auto p-4 space-y-3" id="review-comments">
      {initialReview.comments.map((c) => (
        <div class="bg-gray-50 rounded-lg p-3" data-comment-id={c.id}>
          <div class="flex justify-between items-start">
            <p class="text-xs font-poppins font-semibold text-gray-700">{c.name}</p>
            {c.email === userEmail && (
              <button class="review-delete-comment text-gray-400 hover:text-red-500 text-xs" data-id={c.id}>X</button>
            )}
          </div>
          <p class="text-sm text-gray-600 mt-1">{c.text}</p>
          <p class="text-xs text-gray-400 mt-1">{new Date(c.createdAt).toLocaleString()}</p>
        </div>
      ))}
    </div>

    <!-- Add comment -->
    <div class="p-4 border-t border-gray-100">
      <textarea
        id="review-comment-input"
        class="w-full border border-gray-200 rounded-lg p-2 text-sm resize-none focus:outline-none focus:ring-2 focus:ring-emerald-500"
        rows="2"
        placeholder="Add a comment..."
      ></textarea>
      <button
        id="review-comment-submit"
        class="mt-2 w-full py-2 bg-gray-800 text-white rounded-lg text-sm font-poppins font-semibold hover:bg-gray-900 transition-colors"
      >
        Comment
      </button>
    </div>
  </div>
</div>

<script>
  const panel = document.getElementById('review-panel')!;
  const body = document.getElementById('review-body')!;
  const toggle = document.getElementById('review-toggle')!;
  const slug = panel.dataset.slug!;
  const email = panel.dataset.email!;

  let collapsed = false;
  toggle.addEventListener('click', () => {
    collapsed = !collapsed;
    body.classList.toggle('hidden', collapsed);
  });

  async function api(action: string, extra: Record<string, string> = {}) {
    const res = await fetch(`/api/reviews/${slug}`, {
      method: 'POST',
      headers: { 'content-type': 'application/json' },
      body: JSON.stringify({ action, ...extra }),
    });
    return res.json();
  }

  function renderComments(data: any) {
    const container = document.getElementById('review-comments')!;
    container.innerHTML = data.comments
      .map(
        (c: any) => `
        <div class="bg-gray-50 rounded-lg p-3" data-comment-id="${c.id}">
          <div class="flex justify-between items-start">
            <p class="text-xs font-poppins font-semibold text-gray-700">${c.name}</p>
            ${c.email === email ? `<button class="review-delete-comment text-gray-400 hover:text-red-500 text-xs" data-id="${c.id}">X</button>` : ''}
          </div>
          <p class="text-sm text-gray-600 mt-1">${c.text.replace(/</g, '&lt;')}</p>
          <p class="text-xs text-gray-400 mt-1">${new Date(c.createdAt).toLocaleString()}</p>
        </div>`
      )
      .join('');
    bindDeleteButtons();
  }

  function updateApprovalUI(data: any) {
    const btn = document.getElementById('review-approve-btn')! as HTMLButtonElement;
    const count = document.getElementById('review-approval-count')!;
    const approvers = document.getElementById('review-approvers')!;
    const isApproved = data.approved.some((a: any) => a.email === email);

    btn.dataset.approved = isApproved ? 'true' : 'false';
    btn.textContent = isApproved ? 'Approved' : 'Approve';
    btn.className = `w-full py-2 px-4 rounded-lg text-sm font-poppins font-semibold transition-colors ${
      isApproved
        ? 'bg-emerald-100 text-emerald-800 border border-emerald-300'
        : 'bg-emerald-600 text-white hover:bg-emerald-700'
    }`;
    count.textContent = String(data.approved.length);
    approvers.innerHTML = data.approved
      .map((a: any) => `<p class="text-xs text-gray-500 font-poppins">${a.name} - ${new Date(a.at).toLocaleDateString()}</p>`)
      .join('');
  }

  document.getElementById('review-approve-btn')!.addEventListener('click', async () => {
    const btn = document.getElementById('review-approve-btn')! as HTMLButtonElement;
    const action = btn.dataset.approved === 'true' ? 'unapprove' : 'approve';
    const data = await api(action);
    updateApprovalUI(data);
  });

  document.getElementById('review-comment-submit')!.addEventListener('click', async () => {
    const input = document.getElementById('review-comment-input')! as HTMLTextAreaElement;
    const text = input.value.trim();
    if (!text) return;
    const data = await api('comment', { text });
    renderComments(data);
    input.value = '';
  });

  function bindDeleteButtons() {
    document.querySelectorAll('.review-delete-comment').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const commentId = (btn as HTMLElement).dataset.id!;
        const data = await api('deleteComment', { commentId });
        renderComments(data);
      });
    });
  }
  bindDeleteButtons();
</script>
