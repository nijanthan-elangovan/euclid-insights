---
interface Props {
  headings: { depth: number; slug: string; text: string }[];
}

const { headings } = Astro.props;
const tocHeadings = headings.filter(h => h.depth <= 3);
---

{tocHeadings.length > 0 && (
  <nav class="bg-euclid-gray-light rounded-2xl p-5">
    <h4 class="font-poppins font-semibold text-sm text-gray-500 uppercase tracking-wider mb-4">Contents</h4>
    <ul class="space-y-2">
      {tocHeadings.map((heading) => (
        <li>
          <a
            href={`#${heading.slug}`}
            class={`block text-sm text-gray-500 hover:text-euclid-teal transition-colors leading-snug ${
              heading.depth === 3 ? 'pl-4 text-xs' : ''
            }`}
          >
            {heading.text}
          </a>
        </li>
      ))}
    </ul>
  </nav>
)}
