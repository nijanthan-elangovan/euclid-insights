---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles', ({ data }) => {
  return data.status === 'published';
});

const articles = allArticles.sort(
  (a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime()
);

const featured = articles.find(a => a.data.featured) || articles[0];
const rest = articles.filter(a => a.id !== featured?.id);

const categories = [
  { slug: 'ai-ml', name: 'AI & ML in BFSI', icon: 'M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z', color: 'from-blue-500 to-blue-700' },
  { slug: 'digital-transformation', name: 'Digital Transformation', icon: 'M13 10V3L4 14h7v7l9-11h-7z', color: 'from-purple-500 to-purple-700' },
  { slug: 'cloud', name: 'Cloud Enablement', icon: 'M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z', color: 'from-sky-500 to-sky-700' },
  { slug: 'cybersecurity', name: 'Cybersecurity & AI', icon: 'M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z', color: 'from-red-500 to-red-700' },
  { slug: 'talent', name: 'AI Talent & Staffing', icon: 'M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z', color: 'from-green-500 to-green-700' },
];
---

<BaseLayout title="Euclid Insights — AI & Technology Thought Leadership">
  <!-- Hero Section -->
  <section class="gradient-bg relative overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute top-20 left-20 w-80 h-80 bg-euclid-teal rounded-full blur-3xl animate-pulse"></div>
      <div class="absolute bottom-20 right-20 w-96 h-96 bg-euclid-cyan rounded-full blur-3xl animate-pulse" style="animation-delay: 1s"></div>
    </div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-32 relative">
      <div class="max-w-3xl">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 bg-white/10 rounded-full text-white/80 text-sm font-poppins mb-6 backdrop-blur-sm">
          <span class="w-2 h-2 bg-euclid-green rounded-full animate-pulse"></span>
          Thought Leadership Series
        </div>
        <h1 class="text-4xl md:text-6xl font-poppins font-bold text-white leading-tight mb-6">
          AI & Technology<br/>
          <span class="text-euclid-cyan">for Business</span>
        </h1>
        <p class="text-lg md:text-xl text-white/70 font-roboto leading-relaxed mb-8 max-w-2xl">
          Expert insights on AI, Cloud, Cybersecurity, and Digital Transformation from Euclid Innovations. Helping enterprises turn technology into competitive advantage.
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="#articles" class="inline-flex items-center px-6 py-3 bg-white text-euclid-navy font-poppins font-medium rounded-full transition-all duration-200 hover:shadow-lg hover:-translate-y-0.5">
            Read Latest Articles
            <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </a>
          <a href="/rss.xml" class="btn-outline !border-white/30 !text-white hover:!bg-white/10">
            <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 24 24"><path d="M6.18 15.64a2.18 2.18 0 012.18 2.18C8.36 19 7.38 20 6.18 20C5 20 4 19 4 17.82a2.18 2.18 0 012.18-2.18M4 4.44A15.56 15.56 0 0119.56 20h-2.83A12.73 12.73 0 004 7.27V4.44m0 5.66a9.9 9.9 0 019.9 9.9h-2.83A7.07 7.07 0 004 12.93V10.1z"/></svg>
            Subscribe via RSS
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Categories -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 -mt-8 relative z-10 mb-16">
    <div class="grid grid-cols-2 md:grid-cols-5 gap-3">
      {categories.map((cat) => (
        <a href={`/category/${cat.slug}`} class="bg-white rounded-xl p-4 shadow-sm border border-gray-100 hover:shadow-lg hover:-translate-y-1 transition-all group text-center">
          <div class={`w-10 h-10 mx-auto mb-2 rounded-lg bg-gradient-to-br ${cat.color} flex items-center justify-center`}>
            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={cat.icon}/>
            </svg>
          </div>
          <span class="text-xs font-poppins font-medium text-gray-600 group-hover:text-euclid-teal transition-colors">{cat.name}</span>
        </a>
      ))}
    </div>
  </section>

  <!-- Articles Grid -->
  <section id="articles" class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-20">
    <div class="flex items-center justify-between mb-10">
      <h2 class="text-3xl font-poppins font-bold text-euclid-navy">Latest Articles</h2>
    </div>

    {articles.length === 0 ? (
      <div class="text-center py-20">
        <p class="text-gray-400 font-poppins">No articles published yet. Check back soon!</p>
      </div>
    ) : (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {featured && (
          <ArticleCard
            title={featured.data.title}
            description={featured.data.description}
            pubDate={featured.data.pubDate}
            category={featured.data.category}
            tags={featured.data.tags}
            coverImage={featured.data.coverImage}
            readTime={featured.data.readTime}
            slug={featured.id}
            featured={true}
          />
        )}
        {rest.map((article) => (
          <ArticleCard
            title={article.data.title}
            description={article.data.description}
            pubDate={article.data.pubDate}
            category={article.data.category}
            tags={article.data.tags}
            coverImage={article.data.coverImage}
            readTime={article.data.readTime}
            slug={article.id}
          />
        ))}
      </div>
    )}
  </section>

  <!-- CTA -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-20">
    <div class="gradient-bg rounded-3xl p-10 md:p-16 text-center relative overflow-hidden">
      <div class="absolute inset-0 opacity-10">
        <div class="absolute top-0 right-0 w-64 h-64 bg-white rounded-full blur-3xl"></div>
      </div>
      <div class="relative">
        <h2 class="text-3xl md:text-4xl font-poppins font-bold text-white mb-4">Transform Your Business with AI</h2>
        <p class="text-white/70 text-lg max-w-2xl mx-auto mb-8">Euclid Innovations delivers impactful AI, Cloud, and Digital Transformation solutions for banking, financial services, and enterprise clients.</p>
        <a href="https://euclidinnovations.com/pages/contactus/" target="_blank" class="inline-flex items-center px-8 py-4 bg-white text-euclid-navy font-poppins font-semibold rounded-full hover:shadow-xl transition-all duration-200 hover:-translate-y-0.5">
          Schedule a Consultation
          <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
