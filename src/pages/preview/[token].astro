---
import { getCollection, render } from 'astro:content';
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import ReviewPanel from '../../components/ReviewPanel.astro';
import AdminPanel from '../../components/AdminPanel.astro';
import { assertMicrosoftPreviewConfig, getPreviewSession } from '../../lib/microsoft-auth';
import { getUserRole, getReview } from '../../lib/store';

export const prerender = false;

try {
  assertMicrosoftPreviewConfig();
} catch (configError) {
  return new Response((configError as Error).message, { status: 500 });
}

const session = getPreviewSession(Astro.cookies);
if (!session) {
  const loginUrl = new URL('/auth/microsoft/login', Astro.url);
  loginUrl.searchParams.set('returnTo', Astro.url.pathname);
  return Astro.redirect(`${loginUrl.pathname}${loginUrl.search}`);
}

const previewToken = Astro.params.token;
const previewArticles = await getCollection('articles', ({ data }) => {
  return (
    (data.status === 'review' || data.status === 'draft' || data.status === 'scheduled') &&
    data.previewToken === previewToken
  );
});
const article = previewArticles[0];

if (!article) {
  return new Response('Preview article not found', { status: 404 });
}

const { Content, headings } = await render(article);
const previewData = { ...article.data, status: 'review' as const };
const role = getUserRole(session.email);
const review = getReview(article.slug);
const pubDateStr = new Date(article.data.pubDate).toISOString().split('T')[0];
---

<ArticleLayout frontmatter={previewData} headings={headings} previewSession={session} showPanels={true}>
  <Content />

  <Fragment slot="panels">
    <ReviewPanel
      slug={article.slug}
      userEmail={session.email}
      userName={session.name}
      initialReview={review}
    />

    {role === 'admin' && (
      <AdminPanel
        slug={article.slug}
        currentStatus={article.data.status || 'draft'}
        currentPubDate={pubDateStr}
        currentPreviewToken={article.data.previewToken || ''}
      />
    )}
  </Fragment>
</ArticleLayout>
