---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  canonicalUrl?: string;
  noIndex?: boolean;
}

const {
  title,
  description = 'Insights on AI, Cloud, Cybersecurity & Digital Transformation from Euclid Innovations',
  ogImage = 'http://euclidinnovations.com/wp-content/uploads/2023/01/cropped-Logo-Icon-Transparent-shadow.png',
  ogType = 'website',
  canonicalUrl,
  noIndex = false,
} = Astro.props;

const siteUrl = 'https://insights.euclidinnovations.com';
const fullOgImage = ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`;
const canonical = canonicalUrl || Astro.url.href;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO -->
    <title>{title} | Euclid Insights</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noIndex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Open Graph / LinkedIn -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={fullOgImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="Euclid Insights" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={fullOgImage} />

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="http://euclidinnovations.com/wp-content/uploads/2023/01/cropped-Logo-Icon-Transparent-shadow.png" />

    <!-- RSS -->
    <link rel="alternate" type="application/rss+xml" title="Euclid Insights RSS" href="/rss.xml" />

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "Euclid Insights",
      "url": siteUrl,
      "publisher": {
        "@type": "Organization",
        "name": "Euclid Innovations",
        "url": "https://euclidinnovations.com",
        "logo": "http://euclidinnovations.com/wp-content/uploads/2023/01/cropped-Logo-Icon-Transparent-shadow.png"
      }
    })} />
  </head>
  <body class="min-h-screen flex flex-col bg-white">
    <!-- Header -->
    <header class="sticky top-0 z-50 bg-white/95 backdrop-blur-md border-b border-gray-100">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16">
          <a href="/" class="flex items-center gap-3 group">
            <img
              src="https://euclidinnovations.com/wp-content/uploads/2023/06/Logo-Icon-Transparent-BG.png"
              alt="Euclid Innovations"
              class="h-9 w-9"
              loading="eager"
            />
            <div>
              <span class="font-poppins font-semibold text-euclid-navy text-lg">Euclid</span>
              <span class="font-poppins font-light text-euclid-teal text-lg ml-1">Insights</span>
            </div>
          </a>

          <!-- Desktop Nav -->
          <nav class="hidden md:flex items-center gap-8">
            <a href="/" class="font-poppins text-sm font-medium text-gray-600 hover:text-euclid-teal transition-colors">Home</a>
            <a href="/category/ai-ml" class="font-poppins text-sm font-medium text-gray-600 hover:text-euclid-teal transition-colors">AI & ML</a>
            <a href="/category/cloud" class="font-poppins text-sm font-medium text-gray-600 hover:text-euclid-teal transition-colors">Cloud</a>
            <a href="/category/cybersecurity" class="font-poppins text-sm font-medium text-gray-600 hover:text-euclid-teal transition-colors">Cybersecurity</a>
            <a href="/category/talent" class="font-poppins text-sm font-medium text-gray-600 hover:text-euclid-teal transition-colors">Talent</a>
            <a href="https://euclidinnovations.com/pages/contactus/" target="_blank" class="btn-primary text-sm">Get in Touch</a>
          </nav>

          <!-- Mobile menu button -->
          <button id="mobile-menu-btn" class="md:hidden p-2 text-gray-600 hover:text-euclid-teal" aria-label="Menu">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
            </svg>
          </button>
        </div>
      </div>

      <!-- Mobile Nav -->
      <div id="mobile-menu" class="hidden md:hidden border-t border-gray-100 bg-white">
        <div class="px-4 py-4 space-y-3">
          <a href="/" class="block font-poppins text-sm font-medium text-gray-600 hover:text-euclid-teal">Home</a>
          <a href="/category/ai-ml" class="block font-poppins text-sm font-medium text-gray-600 hover:text-euclid-teal">AI & ML</a>
          <a href="/category/cloud" class="block font-poppins text-sm font-medium text-gray-600 hover:text-euclid-teal">Cloud</a>
          <a href="/category/cybersecurity" class="block font-poppins text-sm font-medium text-gray-600 hover:text-euclid-teal">Cybersecurity</a>
          <a href="/category/talent" class="block font-poppins text-sm font-medium text-gray-600 hover:text-euclid-teal">Talent</a>
          <a href="https://euclidinnovations.com/pages/contactus/" target="_blank" class="btn-primary text-sm w-full justify-center">Get in Touch</a>
        </div>
      </div>
    </header>

    <!-- Main Content -->
    <main class="flex-1">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="gradient-bg text-white mt-20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-10">
          <div class="md:col-span-2">
            <div class="flex items-center gap-3 mb-4">
              <img
                src="http://euclidinnovations.com/wp-content/uploads/2023/01/cropped-Logo-Icon-Transparent-shadow.png"
                alt="Euclid Innovations"
                class="h-10 w-10 brightness-200"
              />
              <div>
                <span class="font-poppins font-semibold text-white text-xl">Euclid</span>
                <span class="font-poppins font-light text-euclid-cyan text-xl ml-1">Insights</span>
              </div>
            </div>
            <p class="text-white/70 text-sm leading-relaxed max-w-md">
              Thought leadership on AI, Cloud, Cybersecurity, and Digital Transformation from the experts at Euclid Innovations. Impactful Solutions. Elevated Tech Talent.
            </p>
          </div>
          <div>
            <h4 class="font-poppins font-semibold text-sm uppercase tracking-wider mb-4 text-euclid-cyan">Topics</h4>
            <ul class="space-y-2 text-sm text-white/70">
              <li><a href="/category/ai-ml" class="hover:text-white transition-colors">AI in Banking</a></li>
              <li><a href="/category/digital-transformation" class="hover:text-white transition-colors">Digital Transformation</a></li>
              <li><a href="/category/cloud" class="hover:text-white transition-colors">Cloud Enablement</a></li>
              <li><a href="/category/cybersecurity" class="hover:text-white transition-colors">Cybersecurity</a></li>
              <li><a href="/category/talent" class="hover:text-white transition-colors">AI Talent</a></li>
            </ul>
          </div>
          <div>
            <h4 class="font-poppins font-semibold text-sm uppercase tracking-wider mb-4 text-euclid-cyan">Company</h4>
            <ul class="space-y-2 text-sm text-white/70">
              <li><a href="https://euclidinnovations.com" target="_blank" class="hover:text-white transition-colors">Main Website</a></li>
              <li><a href="https://euclidinnovations.com/pages/contactus/" target="_blank" class="hover:text-white transition-colors">Contact Us</a></li>
              <li><a href="https://www.linkedin.com/company/euclidinnovations" target="_blank" class="hover:text-white transition-colors">LinkedIn</a></li>
              <li><a href="/rss.xml" class="hover:text-white transition-colors">RSS Feed</a></li>
            </ul>
          </div>
        </div>
        <div class="border-t border-white/10 mt-12 pt-8 flex flex-col md:flex-row justify-between items-center gap-4">
          <p class="text-white/50 text-xs">
            &copy; {new Date().getFullYear()} Euclid Innovations. All rights reserved. Charlotte, NC | Hyderabad | Bangalore
          </p>
          <div class="flex gap-4">
            <a href="https://www.linkedin.com/company/euclidinnovations" target="_blank" class="text-white/50 hover:text-euclid-cyan transition-colors" aria-label="LinkedIn">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            </a>
          </div>
        </div>
      </div>
    </footer>

    <!-- Mobile menu toggle -->
    <script>
      document.getElementById('mobile-menu-btn')?.addEventListener('click', () => {
        document.getElementById('mobile-menu')?.classList.toggle('hidden');
      });
    </script>
  </body>
</html>
