---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  canonicalUrl?: string;
  noIndex?: boolean;
}

const {
  title,
  description = 'Insights on AI, Cloud, Cybersecurity & Digital Transformation from Euclid Innovations',
  ogImage = 'http://euclidinnovations.com/wp-content/uploads/2023/01/cropped-Logo-Icon-Transparent-shadow.png',
  ogType = 'website',
  canonicalUrl,
  noIndex = false,
} = Astro.props;

const siteUrl = 'https://insights.euclidinnovations.com';
const mainSite = 'https://euclidinnovations.com';
const fullOgImage = ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`;
const canonical = canonicalUrl || Astro.url.href;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO -->
    <title>{title} | Euclid Insights</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noIndex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Open Graph / LinkedIn -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={fullOgImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="Euclid Insights" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={fullOgImage} />

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="http://euclidinnovations.com/wp-content/uploads/2023/01/cropped-Logo-Icon-Transparent-shadow.png" />

    <!-- RSS -->
    <link rel="alternate" type="application/rss+xml" title="Euclid Insights RSS" href="/rss.xml" />

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "Euclid Insights",
      "url": siteUrl,
      "publisher": {
        "@type": "Organization",
        "name": "Euclid Innovations",
        "url": mainSite,
        "logo": "http://euclidinnovations.com/wp-content/uploads/2023/01/cropped-Logo-Icon-Transparent-shadow.png"
      }
    })} />
  </head>
  <body class="min-h-screen flex flex-col bg-white">
    <!-- Header — mirrors euclidinnovations.com -->
    <header class="sticky top-0 z-50 bg-white border-b border-[#eaeaea]">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-20">
          <!-- Logo -->
          <a href={mainSite} class="flex items-center gap-3 shrink-0">
            <img
              src="https://euclidinnovations.com/wp-content/uploads/2023/06/Logo-Icon-Transparent-BG.png"
              alt="Euclid Innovations"
              class="h-10 w-10"
              loading="eager"
            />
            <span class="font-poppins font-semibold text-[#1e293b] text-xl hidden sm:inline">Euclid Innovations</span>
          </a>

          <!-- Desktop Nav -->
          <nav class="hidden lg:flex items-center gap-1">
            <!-- About Us -->
            <div class="relative group">
              <button class="nav-link flex items-center gap-1">
                About Us
                <svg class="w-3.5 h-3.5 mt-0.5 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
              </button>
              <div class="dropdown-menu">
                <a href={`${mainSite}/pages/about-us/#vision`} class="dropdown-item">Our Vision</a>
                <a href={`${mainSite}/pages/about-us/#team`} class="dropdown-item">Our Team</a>
                <a href={`${mainSite}/pages/about-us/#backg`} class="dropdown-item">Our Background</a>
              </div>
            </div>

            <!-- Industries -->
            <div class="relative group">
              <button class="nav-link flex items-center gap-1">
                Industries
                <svg class="w-3.5 h-3.5 mt-0.5 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
              </button>
              <div class="dropdown-menu">
                <a href={`${mainSite}/pages/industries/#cm`} class="dropdown-item">Capital Markets</a>
                <a href={`${mainSite}/pages/industries/#ib`} class="dropdown-item">Investment Banking</a>
                <a href={`${mainSite}/pages/industries/#wm`} class="dropdown-item">Wealth Management</a>
                <a href={`${mainSite}/pages/industries/#cb`} class="dropdown-item">Commercial Banking</a>
                <a href={`${mainSite}/pages/industries/#pay`} class="dropdown-item">Payments</a>
                <a href={`${mainSite}/pages/industries/#ins`} class="dropdown-item">Insurance</a>
                <a href={`${mainSite}/pages/industries/#health`} class="dropdown-item">Healthcare</a>
                <a href={`${mainSite}/pages/industries/#ret`} class="dropdown-item">Retail</a>
              </div>
            </div>

            <!-- Expertise -->
            <div class="relative group">
              <button class="nav-link flex items-center gap-1">
                Expertise
                <svg class="w-3.5 h-3.5 mt-0.5 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
              </button>
              <div class="dropdown-menu">
                <a href={`${mainSite}/expertise/ai-ml/`} class="dropdown-item">AI/ML</a>
                <a href={`${mainSite}/expertise/banking-regulatory-risk/`} class="dropdown-item">Banking & Capital Markets</a>
                <a href={`${mainSite}/expertise/cloud-migration/`} class="dropdown-item">Cloud Enablement</a>
                <a href={`${mainSite}/expertise/digital-transformation/`} class="dropdown-item">Digital Transformation</a>
                <a href={`${mainSite}/pages/emerging-talents/`} class="dropdown-item">Emerging Talent</a>
                <a href={`${mainSite}/expertise/cyber-security/`} class="dropdown-item">Cyber Security</a>
              </div>
            </div>

            <!-- Products -->
            <div class="relative group">
              <button class="nav-link flex items-center gap-1">
                Products
                <svg class="w-3.5 h-3.5 mt-0.5 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
              </button>
              <div class="dropdown-menu">
                <a href="https://caml.live/" target="_blank" class="dropdown-item">Caml</a>
                <a href="https://qgraph.app/" target="_blank" class="dropdown-item">qGraph</a>
              </div>
            </div>

            <!-- Services -->
            <div class="relative group">
              <button class="nav-link flex items-center gap-1">
                Services
                <svg class="w-3.5 h-3.5 mt-0.5 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
              </button>
              <div class="dropdown-menu">
                <a href={`${mainSite}/services/project-service/`} class="dropdown-item">Project Service</a>
                <a href={`${mainSite}/services/staffing-services/`} class="dropdown-item">Staffing Service</a>
                <a href={`${mainSite}/services/captive-offshore-service/`} class="dropdown-item">Captive Offshore Service</a>
              </div>
            </div>

            <!-- Case Studies -->
            <a href={`${mainSite}/case-studies/`} class="nav-link">Case Studies</a>

            <!-- Insights (current site - highlighted) -->
            <a href="/" class="nav-link nav-link-active">Insights</a>

            <!-- Schedule a Call -->
            <a href={`${mainSite}/pages/contactus/`} class="ml-2 inline-flex items-center px-5 py-2.5 bg-[#046bd2] text-white font-poppins font-medium text-sm rounded-md hover:bg-[#045cb4] transition-colors">
              Schedule a Call
            </a>
          </nav>

          <!-- Mobile menu button -->
          <button id="mobile-menu-btn" class="lg:hidden p-2 text-[#334155] hover:text-[#045cb4]" aria-label="Menu">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
            </svg>
          </button>
        </div>
      </div>

      <!-- Mobile Nav -->
      <div id="mobile-menu" class="hidden lg:hidden border-t border-[#eaeaea] bg-white max-h-[80vh] overflow-y-auto">
        <div class="px-4 py-4 space-y-1">
          <!-- Mobile accordion menus -->
          <div class="mobile-group">
            <button class="mobile-toggle">About Us <span class="mobile-arrow">+</span></button>
            <div class="mobile-submenu">
              <a href={`${mainSite}/pages/about-us/#vision`}>Our Vision</a>
              <a href={`${mainSite}/pages/about-us/#team`}>Our Team</a>
              <a href={`${mainSite}/pages/about-us/#backg`}>Our Background</a>
            </div>
          </div>
          <div class="mobile-group">
            <button class="mobile-toggle">Industries <span class="mobile-arrow">+</span></button>
            <div class="mobile-submenu">
              <a href={`${mainSite}/pages/industries/#cm`}>Capital Markets</a>
              <a href={`${mainSite}/pages/industries/#ib`}>Investment Banking</a>
              <a href={`${mainSite}/pages/industries/#wm`}>Wealth Management</a>
              <a href={`${mainSite}/pages/industries/#cb`}>Commercial Banking</a>
              <a href={`${mainSite}/pages/industries/#pay`}>Payments</a>
              <a href={`${mainSite}/pages/industries/#ins`}>Insurance</a>
              <a href={`${mainSite}/pages/industries/#health`}>Healthcare</a>
              <a href={`${mainSite}/pages/industries/#ret`}>Retail</a>
            </div>
          </div>
          <div class="mobile-group">
            <button class="mobile-toggle">Expertise <span class="mobile-arrow">+</span></button>
            <div class="mobile-submenu">
              <a href={`${mainSite}/expertise/ai-ml/`}>AI/ML</a>
              <a href={`${mainSite}/expertise/banking-regulatory-risk/`}>Banking & Capital Markets</a>
              <a href={`${mainSite}/expertise/cloud-migration/`}>Cloud Enablement</a>
              <a href={`${mainSite}/expertise/digital-transformation/`}>Digital Transformation</a>
              <a href={`${mainSite}/pages/emerging-talents/`}>Emerging Talent</a>
              <a href={`${mainSite}/expertise/cyber-security/`}>Cyber Security</a>
            </div>
          </div>
          <div class="mobile-group">
            <button class="mobile-toggle">Products <span class="mobile-arrow">+</span></button>
            <div class="mobile-submenu">
              <a href="https://caml.live/" target="_blank">Caml</a>
              <a href="https://qgraph.app/" target="_blank">qGraph</a>
            </div>
          </div>
          <div class="mobile-group">
            <button class="mobile-toggle">Services <span class="mobile-arrow">+</span></button>
            <div class="mobile-submenu">
              <a href={`${mainSite}/services/project-service/`}>Project Service</a>
              <a href={`${mainSite}/services/staffing-services/`}>Staffing Service</a>
              <a href={`${mainSite}/services/captive-offshore-service/`}>Captive Offshore Service</a>
            </div>
          </div>
          <a href={`${mainSite}/case-studies/`} class="block font-poppins text-sm font-medium text-[#334155] hover:text-[#045cb4] py-3 border-b border-gray-100">Case Studies</a>
          <a href="/" class="block font-poppins text-sm font-semibold text-[#045cb4] py-3 border-b border-gray-100">Insights</a>
          <a href={`${mainSite}/pages/contactus/`} class="block text-center mt-3 px-5 py-2.5 bg-[#046bd2] text-white font-poppins font-medium text-sm rounded-md hover:bg-[#045cb4] transition-colors">Schedule a Call</a>
        </div>
      </div>
    </header>

    <!-- Main Content -->
    <main class="flex-1">
      <slot />
    </main>

    <!-- Footer — mirrors euclidinnovations.com -->
    <footer class="bg-[#1e293b] text-white mt-20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">
          <!-- Brand -->
          <div>
            <div class="flex items-center gap-3 mb-5">
              <img
                src="http://euclidinnovations.com/wp-content/uploads/2023/01/cropped-Logo-Icon-Transparent-shadow.png"
                alt="Euclid Innovations"
                class="h-10 w-10"
              />
              <span class="font-poppins font-semibold text-white text-lg">Euclid Innovations</span>
            </div>
            <p class="text-[#94a3b8] text-sm leading-relaxed">
              Impactful Solutions. Elevated Tech Talent. We engineer a better tomorrow through AI, Cloud, and Digital Transformation.
            </p>
            <div class="flex gap-3 mt-5">
              <a href="https://www.linkedin.com/company/euclidinnovations" target="_blank" class="w-9 h-9 rounded-full bg-white/10 flex items-center justify-center hover:bg-[#046bd2] transition-colors" aria-label="LinkedIn">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
              </a>
            </div>
          </div>

          <!-- Expertise -->
          <div>
            <h4 class="font-poppins font-semibold text-sm uppercase tracking-wider mb-5 text-white">Expertise</h4>
            <ul class="space-y-2.5 text-sm text-[#94a3b8]">
              <li><a href={`${mainSite}/expertise/ai-ml/`} class="hover:text-white transition-colors">AI/ML</a></li>
              <li><a href={`${mainSite}/expertise/banking-regulatory-risk/`} class="hover:text-white transition-colors">Banking & Capital Markets</a></li>
              <li><a href={`${mainSite}/expertise/cloud-migration/`} class="hover:text-white transition-colors">Cloud Enablement</a></li>
              <li><a href={`${mainSite}/expertise/digital-transformation/`} class="hover:text-white transition-colors">Digital Transformation</a></li>
              <li><a href={`${mainSite}/expertise/cyber-security/`} class="hover:text-white transition-colors">Cyber Security</a></li>
              <li><a href={`${mainSite}/pages/emerging-talents/`} class="hover:text-white transition-colors">Emerging Talent</a></li>
            </ul>
          </div>

          <!-- Services -->
          <div>
            <h4 class="font-poppins font-semibold text-sm uppercase tracking-wider mb-5 text-white">Services</h4>
            <ul class="space-y-2.5 text-sm text-[#94a3b8]">
              <li><a href={`${mainSite}/services/project-service/`} class="hover:text-white transition-colors">Project Service</a></li>
              <li><a href={`${mainSite}/services/staffing-services/`} class="hover:text-white transition-colors">Staffing Service</a></li>
              <li><a href={`${mainSite}/services/captive-offshore-service/`} class="hover:text-white transition-colors">Captive Offshore Service</a></li>
              <li><a href={`${mainSite}/case-studies/`} class="hover:text-white transition-colors">Case Studies</a></li>
              <li><a href="/" class="hover:text-white transition-colors">Insights Blog</a></li>
            </ul>
          </div>

          <!-- Contact -->
          <div>
            <h4 class="font-poppins font-semibold text-sm uppercase tracking-wider mb-5 text-white">Contact</h4>
            <ul class="space-y-3 text-sm text-[#94a3b8]">
              <li class="flex items-start gap-2">
                <svg class="w-4 h-4 mt-0.5 shrink-0 text-[#046bd2]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                <span>Charlotte, NC<br/>Hyderabad | Bangalore</span>
              </li>
              <li>
                <a href={`${mainSite}/pages/contactus/`} class="inline-flex items-center gap-2 text-[#046bd2] hover:text-white transition-colors font-medium">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
                  Schedule a Call
                </a>
              </li>
            </ul>
          </div>
        </div>

        <!-- Bottom bar -->
        <div class="border-t border-white/10 mt-12 pt-8 flex flex-col md:flex-row justify-between items-center gap-4">
          <p class="text-[#94a3b8] text-xs">
            &copy; {new Date().getFullYear()} Euclid Innovations. All rights reserved.
          </p>
          <div class="flex gap-6 text-xs text-[#94a3b8]">
            <a href={`${mainSite}/pages/about-us/`} class="hover:text-white transition-colors">About Us</a>
            <a href={`${mainSite}/pages/contactus/`} class="hover:text-white transition-colors">Contact</a>
            <a href="/rss.xml" class="hover:text-white transition-colors">RSS Feed</a>
          </div>
        </div>
      </div>
    </footer>

    <!-- Menu interactions -->
    <script>
      // Mobile menu toggle
      document.getElementById('mobile-menu-btn')?.addEventListener('click', () => {
        document.getElementById('mobile-menu')?.classList.toggle('hidden');
      });

      // Mobile accordion submenus
      document.querySelectorAll('.mobile-toggle').forEach(btn => {
        btn.addEventListener('click', () => {
          const submenu = btn.nextElementSibling;
          const arrow = btn.querySelector('.mobile-arrow');
          if (submenu && arrow) {
            submenu.classList.toggle('hidden');
            arrow.textContent = submenu.classList.contains('hidden') ? '+' : '-';
          }
        });
      });
    </script>
  </body>
</html>
