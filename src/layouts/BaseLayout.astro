---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  canonicalUrl?: string;
  noIndex?: boolean;
}

const {
  title,
  description = 'Insights on AI, Cloud, Cybersecurity & Digital Transformation from Euclid Innovations',
  ogImage = 'http://euclidinnovations.com/wp-content/uploads/2023/01/cropped-Logo-Icon-Transparent-shadow.png',
  ogType = 'website',
  canonicalUrl,
  noIndex = false,
} = Astro.props;

const siteUrl = 'https://insights.euclidinnovations.com';
const mainSite = 'https://euclidinnovations.com';
const fullOgImage = ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`;
const canonical = canonicalUrl || Astro.url.href;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO -->
    <title>{title} | Euclid Insights</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noIndex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Open Graph / LinkedIn -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={fullOgImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="Euclid Insights" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={fullOgImage} />

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="http://euclidinnovations.com/wp-content/uploads/2023/01/cropped-Logo-Icon-Transparent-shadow.png" />

    <!-- RSS -->
    <link rel="alternate" type="application/rss+xml" title="Euclid Insights RSS" href="/rss.xml" />

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "Euclid Insights",
      "url": siteUrl,
      "publisher": {
        "@type": "Organization",
        "name": "Euclid Innovations",
        "url": mainSite,
        "logo": "http://euclidinnovations.com/wp-content/uploads/2023/01/cropped-Logo-Icon-Transparent-shadow.png"
      }
    })} />
  </head>
  <body class="min-h-screen flex flex-col bg-white">
    <!-- Top tagline bar -->
    <div class="header-gradient-bg text-white text-center py-2.5">
      <p class="font-poppins text-sm tracking-wide">Empowering change through impactful <strong class="font-semibold">innovations</strong></p>
    </div>

    <!-- Header — mirrors euclidinnovations.com -->
    <header class="sticky top-0 z-50 bg-white border-b border-[#eaeaea]">
      <div class="max-w-[1200px] mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-[72px]">
          <!-- Logo -->
          <a href={mainSite} class="flex items-center gap-3 shrink-0">
            <img
              src="https://euclidinnovations.com/wp-content/uploads/2023/06/Logo-Icon-Transparent-BG.png"
              alt="Euclid Innovations"
              class="h-12 w-12"
              loading="eager"
            />
            <div class="hidden sm:flex flex-col leading-tight">
              <div>
                <span class="font-poppins font-bold text-[#1e293b] text-[17px] tracking-wide uppercase">Euclid</span>
              </div>
              <div>
                <span class="font-poppins font-normal text-[#1e293b] text-[15px] tracking-wide lowercase">innovations</span>
              </div>
              <span class="font-poppins text-[8px] text-[#94a3b8] tracking-wider uppercase">Impactful Solutions | Projects | Consulting</span>
            </div>
          </a>

          <!-- Desktop Nav -->
          <nav class="hidden xl:flex items-center gap-0">
            <!-- About Us -->
            <div class="relative group">
              <button class="nav-link flex items-center gap-1 uppercase">
                About Us
                <svg class="w-3 h-3 mt-0.5 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
              </button>
              <div class="dropdown-menu">
                <a href={`${mainSite}/pages/about-us/#vision`} class="dropdown-item">Our Vision</a>
                <a href={`${mainSite}/pages/about-us/#team`} class="dropdown-item">Our Team</a>
                <a href={`${mainSite}/pages/about-us/#backg`} class="dropdown-item">Our Background</a>
              </div>
            </div>

            <!-- Industries -->
            <div class="relative group">
              <button class="nav-link flex items-center gap-1 uppercase">
                Industries
                <svg class="w-3 h-3 mt-0.5 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
              </button>
              <div class="dropdown-menu">
                <a href={`${mainSite}/pages/industries/#cm`} class="dropdown-item">Capital Markets</a>
                <a href={`${mainSite}/pages/industries/#ib`} class="dropdown-item">Investment Banking</a>
                <a href={`${mainSite}/pages/industries/#wm`} class="dropdown-item">Wealth Management</a>
                <a href={`${mainSite}/pages/industries/#cb`} class="dropdown-item">Commercial Banking</a>
                <a href={`${mainSite}/pages/industries/#pay`} class="dropdown-item">Payments</a>
                <a href={`${mainSite}/pages/industries/#ins`} class="dropdown-item">Insurance</a>
                <a href={`${mainSite}/pages/industries/#health`} class="dropdown-item">Healthcare</a>
                <a href={`${mainSite}/pages/industries/#ret`} class="dropdown-item">Retail</a>
              </div>
            </div>

            <!-- Expertise -->
            <div class="relative group">
              <button class="nav-link flex items-center gap-1 uppercase">
                Expertise
                <svg class="w-3 h-3 mt-0.5 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
              </button>
              <div class="dropdown-menu">
                <a href={`${mainSite}/expertise/ai-ml/`} class="dropdown-item">AI/ML</a>
                <a href={`${mainSite}/expertise/banking-regulatory-risk/`} class="dropdown-item">Banking & Capital Markets</a>
                <a href={`${mainSite}/expertise/cloud-migration/`} class="dropdown-item">Cloud Enablement</a>
                <a href={`${mainSite}/expertise/digital-transformation/`} class="dropdown-item">Digital Transformation</a>
                <a href={`${mainSite}/pages/emerging-talents/`} class="dropdown-item">Emerging Talent</a>
                <a href={`${mainSite}/expertise/cyber-security/`} class="dropdown-item">Cyber Security</a>
              </div>
            </div>

            <!-- Services -->
            <div class="relative group">
              <button class="nav-link flex items-center gap-1 uppercase">
                Services
                <svg class="w-3 h-3 mt-0.5 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
              </button>
              <div class="dropdown-menu">
                <a href={`${mainSite}/services/project-service/`} class="dropdown-item">Project Service</a>
                <a href={`${mainSite}/services/staffing-services/`} class="dropdown-item">Staffing Service</a>
                <a href={`${mainSite}/services/captive-offshore-service/`} class="dropdown-item">Captive Offshore Service</a>
              </div>
            </div>

            <!-- Case Studies -->
            <a href={`${mainSite}/case-studies/`} class="nav-link uppercase">Case Studies</a>

            <!-- Careers with badge -->
            <div class="relative">
              <a href={`${mainSite}/pages/careers-in/`} class="nav-link uppercase">Careers</a>
              <span class="absolute -top-1 left-1/2 -translate-x-1/2 bg-euclid-teal text-white text-[7px] font-poppins font-bold uppercase px-1.5 py-0.5 rounded-sm whitespace-nowrap leading-none">We're Hiring</span>
            </div>

            <!-- Contact Us button -->
            <a href={`${mainSite}/pages/contactus/`} class="ml-3 inline-flex items-center px-5 py-2 bg-euclid-teal text-white font-poppins font-medium text-sm rounded-full hover:bg-euclid-teal-deep transition-colors">
              Contact Us
            </a>
          </nav>

          <!-- Mobile menu button -->
          <button id="mobile-menu-btn" class="xl:hidden p-2 text-[#334155] hover:text-euclid-teal" aria-label="Menu">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
            </svg>
          </button>
        </div>
      </div>

      <!-- Mobile Nav -->
      <div id="mobile-menu" class="hidden xl:hidden border-t border-[#eaeaea] bg-white max-h-[80vh] overflow-y-auto">
        <div class="px-4 py-4 space-y-1">
          <div class="mobile-group">
            <button class="mobile-toggle">About Us <span class="mobile-arrow">+</span></button>
            <div class="mobile-submenu">
              <a href={`${mainSite}/pages/about-us/#vision`}>Our Vision</a>
              <a href={`${mainSite}/pages/about-us/#team`}>Our Team</a>
              <a href={`${mainSite}/pages/about-us/#backg`}>Our Background</a>
            </div>
          </div>
          <div class="mobile-group">
            <button class="mobile-toggle">Industries <span class="mobile-arrow">+</span></button>
            <div class="mobile-submenu">
              <a href={`${mainSite}/pages/industries/#cm`}>Capital Markets</a>
              <a href={`${mainSite}/pages/industries/#ib`}>Investment Banking</a>
              <a href={`${mainSite}/pages/industries/#wm`}>Wealth Management</a>
              <a href={`${mainSite}/pages/industries/#cb`}>Commercial Banking</a>
              <a href={`${mainSite}/pages/industries/#pay`}>Payments</a>
              <a href={`${mainSite}/pages/industries/#ins`}>Insurance</a>
              <a href={`${mainSite}/pages/industries/#health`}>Healthcare</a>
              <a href={`${mainSite}/pages/industries/#ret`}>Retail</a>
            </div>
          </div>
          <div class="mobile-group">
            <button class="mobile-toggle">Expertise <span class="mobile-arrow">+</span></button>
            <div class="mobile-submenu">
              <a href={`${mainSite}/expertise/ai-ml/`}>AI/ML</a>
              <a href={`${mainSite}/expertise/banking-regulatory-risk/`}>Banking & Capital Markets</a>
              <a href={`${mainSite}/expertise/cloud-migration/`}>Cloud Enablement</a>
              <a href={`${mainSite}/expertise/digital-transformation/`}>Digital Transformation</a>
              <a href={`${mainSite}/pages/emerging-talents/`}>Emerging Talent</a>
              <a href={`${mainSite}/expertise/cyber-security/`}>Cyber Security</a>
            </div>
          </div>
          <div class="mobile-group">
            <button class="mobile-toggle">Services <span class="mobile-arrow">+</span></button>
            <div class="mobile-submenu">
              <a href={`${mainSite}/services/project-service/`}>Project Service</a>
              <a href={`${mainSite}/services/staffing-services/`}>Staffing Service</a>
              <a href={`${mainSite}/services/captive-offshore-service/`}>Captive Offshore Service</a>
            </div>
          </div>
          <a href={`${mainSite}/case-studies/`} class="block font-poppins text-sm font-medium text-[#334155] hover:text-euclid-teal py-3 border-b border-gray-100 uppercase">Case Studies</a>
          <a href={`${mainSite}/pages/careers-in/`} class="block font-poppins text-sm font-medium text-[#334155] hover:text-euclid-teal py-3 border-b border-gray-100 uppercase">Careers</a>
          <a href={`${mainSite}/pages/contactus/`} class="block text-center mt-3 px-5 py-2.5 bg-euclid-teal text-white font-poppins font-medium text-sm rounded-full hover:bg-euclid-teal-deep transition-colors">Contact Us</a>
        </div>
      </div>
    </header>

    <!-- Main Content -->
    <main class="flex-1">
      <slot />
    </main>

    <!-- Footer — mirrors euclidinnovations.com -->
    <footer class="mt-20">
      <!-- Main footer -->
      <div class="header-gradient-bg text-white">
        <div class="max-w-[1200px] mx-auto px-4 sm:px-6 lg:px-8 py-14">
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">
            <!-- Column 1: Links -->
            <div>
              <ul class="space-y-3 text-sm">
                <li><a href={`${mainSite}/expertise/ai-ml/`} class="text-white/90 hover:text-white transition-colors">AI/ML</a></li>
                <li><a href={`${mainSite}/expertise/banking-regulatory-risk/`} class="text-white/90 hover:text-white transition-colors">Banking</a></li>
                <li><a href={`${mainSite}/expertise/cloud-migration/`} class="text-white/90 hover:text-white transition-colors">Cloud Solutions</a></li>
                <li><a href={`${mainSite}/expertise/digital-transformation/`} class="text-white/90 hover:text-white transition-colors">Digital Transformation</a></li>
              </ul>
            </div>

            <!-- Column 2: Links -->
            <div>
              <ul class="space-y-3 text-sm">
                <li><a href={`${mainSite}/pages/about-us/`} class="text-white/90 hover:text-white transition-colors">Who we are</a></li>
                <li><a href={`${mainSite}/pages/careers-in/`} class="text-white/90 hover:text-white transition-colors">Careers</a></li>
                <li><a href={`${mainSite}/pages/contactus/`} class="text-white/90 hover:text-white transition-colors">Schedule a call</a></li>
                <li><a href={`${mainSite}`} class="text-white/90 hover:text-white transition-colors">Brand Kit</a></li>
              </ul>
            </div>

            <!-- Column 3: Newsletter -->
            <div>
              <h4 class="font-poppins font-semibold text-sm mb-4">Get latest jobs right in your inbox!</h4>
              <form class="space-y-3">
                <input
                  type="email"
                  placeholder="Email"
                  class="w-full px-4 py-2.5 rounded border border-white/40 bg-transparent text-white placeholder-white/60 text-sm focus:outline-none focus:border-white"
                />
                <button type="submit" class="w-full px-4 py-2.5 rounded border border-white text-white font-poppins font-medium text-sm hover:bg-white/10 transition-colors">
                  Signup
                </button>
              </form>
            </div>

            <!-- Column 4: Locations -->
            <div class="space-y-4">
              <div class="flex items-center justify-between text-sm">
                <span class="text-white/90">Charlotte, US</span>
                <span class="text-white/60 text-lg leading-none">+</span>
              </div>
              <div class="flex items-center justify-between text-sm">
                <span class="text-white/90">Hyderabad, India</span>
                <span class="text-white/60 text-lg leading-none">+</span>
              </div>
              <div class="flex items-center justify-between text-sm">
                <span class="text-white/90">Bangalore, India</span>
                <span class="text-white/60 text-lg leading-none">+</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Bottom copyright bar -->
      <div class="bg-[#01332e] text-white/70">
        <div class="max-w-[1200px] mx-auto px-4 sm:px-6 lg:px-8 py-4 flex flex-col md:flex-row justify-between items-center gap-3">
          <p class="text-xs font-poppins">
            &copy; {new Date().getFullYear()} | Euclid Innovations &ndash; All Rights Reserved.
          </p>
          <div class="flex items-center gap-2 text-xs">
            <span class="w-2.5 h-2.5 rounded-full bg-green-400 inline-block"></span>
            <span class="text-green-400 font-poppins">All services are online</span>
          </div>
        </div>
      </div>
    </footer>

    <!-- Menu interactions -->
    <script>
      // Mobile menu toggle
      document.getElementById('mobile-menu-btn')?.addEventListener('click', () => {
        document.getElementById('mobile-menu')?.classList.toggle('hidden');
      });

      // Mobile accordion submenus
      document.querySelectorAll('.mobile-toggle').forEach(btn => {
        btn.addEventListener('click', () => {
          const submenu = btn.nextElementSibling;
          const arrow = btn.querySelector('.mobile-arrow');
          if (submenu && arrow) {
            submenu.classList.toggle('hidden');
            arrow.textContent = submenu.classList.contains('hidden') ? '+' : '-';
          }
        });
      });
    </script>
  </body>
</html>
